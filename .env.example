# Django S3 Environment Variables
# Copy this file to .env and fill in your actual AWS credentials

# =====================================
# Django Application Configuration
# =====================================
DEBUG=True
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=127.0.0.1,localhost

# =====================================
# AWS S3 Storage (replace with real keys in your local .env only!)
# =====================================
AWS_ACCESS_KEY_ID=AKIA5ODZ65YM1GGJAFYG #i think each user needs to do this ?
AWS_SECRET_ACCESS_KEY=yd6njbZhuVN7WDleHqB906aGNfhJ7G7iakRAUkdp #i think each user needs to do this ?
AWS_STORAGE_BUCKET_NAME=project-b-17-media-files 
AWS_S3_REGION_NAME=us-east-1

# =====================================
# Database
# (for local development; production uses managed DB)
# =====================================
DATABASE_URL=sqlite:///db.sqlite3

# =====================================
# Django Allauth (Social Authentication)
# =====================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# =====================================
# Django Channels (WebSocket backend)
# =====================================
# For local dev use in-memory layer; production can switch to Redis
CHANNEL_BACKEND=memory
# REDIS_URL=redis://127.0.0.1:6379/0   # Uncomment if using Redis later

# =====================================
# Email (optional - for password resets, verification)
# =====================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=admin@projectb17.local

# =====================================
# Security / Environment
# =====================================
ENVIRONMENT=development